# Optional API keys for the solana-founder-brand skill.
# Required only for mcp/live-test.mjs — the skill itself doesn't need this.
ANTHROPIC_API_KEY=


# All keys are optional — the skill works with none of them set, just with
# the bundled archetype library. Each key upgrades one capability.

# --- X post fetching (for voice grounding) ---

# Recommended: twitterapi.io — $0.15 per 1000 tweets, free signup credit
# Get one at: https://twitterapi.io
TWITTERAPI_IO_KEY=

# Fallback: RapidAPI key (uses twitter-api45 provider by default)
# Get one at: https://rapidapi.com
RAPIDAPI_KEY=

# --- Web search (for founder background enrichment) ---

# Recommended: Tavily — 1000/mo free, no credit card
# Get one at: https://tavily.com
TAVILY_API_KEY=

# Alternative: Exa — $10 one-time credits
# Get one at: https://exa.ai
EXA_API_KEY=

# Alternative: SerpAPI — 100/mo free
# Get one at: https://serpapi.com
SERPAPI_KEY=
